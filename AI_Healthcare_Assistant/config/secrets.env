# Environment secrets — DO NOT commit real keys to version control
# Copy this file to .env and fill in your values

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Feature flags (set to "false" to disable when running fully offline)
ENABLE_WHISPER=true
ENABLE_GOOGLE_STT=true
ENABLE_GTTS=true
OFFLINE_MODE=false

# ── OpenAI (required for GPT-powered AI Chat) ─────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
# Without this key the chat page still works using offline keyword fallback.
OPENAI_API_KEY=

# ── Optional: SMS/webhook for emergency alerts ────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# EMERGENCY_SMS_TO=+977XXXXXXXXXX
# EMERGENCY_SMS_FROM=+1XXXXXXXXXX
